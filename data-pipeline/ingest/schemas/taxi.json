{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaxiRecord",
  "type": "object",
  "properties": {
    "ride_id": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "pickup_zone": {"type": "string"},
    "dropoff_zone": {"type": "string"},
    "passenger_count": {"type": "integer", "minimum": 0}
  },
  "required": ["ride_id", "timestamp", "pickup_zone", "dropoff_zone", "passenger_count"]
}
